# Triton Yellowstone gRPC (optional, for live payout streaming — phase 2)
TRITON_GRPC_ENDPOINT=""
TRITON_GRPC_TOKEN=""

# Indexer poll interval (ms)
INDEXER_POLL_MS="30000"
