{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @agents-go/db generate && pnpm --filter @agents-go/web build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @agents-go/web start:prod",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
